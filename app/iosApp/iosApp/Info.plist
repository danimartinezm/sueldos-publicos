    <key>CFBundleDisplayName</key>
    <string>Sueldos públicos</string>
    <key>CFBundleIdentifier</key>
    <string>info.danielmartinez.sueldos</string>
    <key>CFBundleName</key>
    <string>iosApp</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
